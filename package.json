{
  "name": "@richardgaunt/visual-regression-for-drupal",
  "version": "1.1.0",
  "description": "Visual regression package designed for running visual regression for CivicTheme but can be configured for other Drupal theme's and websites in general.",
  "main": "index.mjs",
  "type": "module",
  "bin": {
    "vr-drupal": "index.mjs"
  },
  "scripts": {
    "start": "node index.mjs",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:features": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/cli-features.test.mjs --testTimeout=10000",
    "test:basic": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/index.test.mjs",
    "test:all": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testTimeout=10000",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "chalk": "^5.3.0",
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.3",
    "inquirer-file-selector": "^0.6.2",
    "js-yaml": "^4.1.0",
    "puppeteer": "^22.5.0",
    "puppeteer-cluster": "^0.24.0",
    "reg-cli": "^0.18.14",
    "semver": "^7.7.2",
    "serve-handler": "^6.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "eslint": "^9.25.1",
    "eslint-plugin-n": "^17.17.0",
    "globals": "^16.4.0",
    "jest": "^30.2.0"
  },
  "engines": {
    "node": ">=22"
  },
  "author": "rgaunt",
  "license": "MIT"
}
