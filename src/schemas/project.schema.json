{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CivicTheme Project Configuration",
  "description": "Schema for CivicTheme Update Helper project configuration files",
  "type": "object",
  "required": ["name", "directoryName"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable name of the project"
    },
    "directoryName": {
      "type": "string",
      "description": "Directory name for storing project files",
      "pattern": "^[a-z0-9-]+$"
    },
    "visual-diff": {
      "type": "object",
      "description": "Visual regression testing configuration",
      "required": ["base_path"],
      "properties": {
        "base_path": {
          "type": "string",
          "description": "Base URL for taking screenshots",
          "format": "uri"
        },
        "paths": {
          "type": "array",
          "description": "URL paths to capture screenshots for",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "viewports": {
          "type": "array",
          "description": "Viewport configurations for screenshots",
          "items": {
            "type": "object",
            "required": ["name", "windowWidth", "windowHeight"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Viewport name (e.g., Mobile, Tablet, Desktop)"
              },
              "windowWidth": {
                "type": "integer",
                "minimum": 320,
                "description": "Window width in pixels"
              },
              "windowHeight": {
                "type": "integer",
                "minimum": 320,
                "description": "Window height in pixels"
              }
            }
          },
          "minItems": 1
        },
        "advanced": {
          "type": "object",
          "description": "Advanced screenshot configuration options",
          "properties": {
            "masking_selectors": {
              "type": "array",
              "description": "CSS selectors for elements to mask during screenshot",
              "items": {
                "type": "string"
              }
            },
            "disable_css_transitions": {
              "type": "boolean",
              "description": "Disable CSS transitions during screenshot capture"
            },
            "hide_mask_selectors": {
              "type": "boolean",
              "description": "Hide mask selectors instead of showing them"
            },
            "replace_images_with_solid_color": {
              "type": "boolean",
              "description": "Replace images with solid color blocks for consistency"
            },
            "settle_delay_ms": {
              "type": "integer",
              "minimum": 0,
              "description": "Delay in milliseconds to wait for page to settle before screenshot"
            }
          }
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the project was created"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the project was last updated"
    },
    "snapshots": {
      "type": "object",
      "description": "Collection of saved snapshot sets",
      "additionalProperties": {
        "type": "object",
        "required": ["directory", "date", "count"],
        "properties": {
          "directory": {
            "type": "string",
            "description": "Directory path where snapshot images are stored"
          },
          "date": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp when snapshot was taken"
          },
          "count": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of screenshots in this snapshot set"
          }
        }
      }
    }
  }
}